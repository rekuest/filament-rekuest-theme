{
    "name": "rekuest/filament-rekuest-theme",
    "description": "Enterprise-grade Filament 5.x theme built for ERP and back-office software: low-noise UI, eye-friendly color system, light/dark parity, accessible contrast — engineered for long operator sessions.",
    "keywords": [
        "rekuest",
        "rekuest srl",
        "laravel",
        "filament",
        "filamentphp",
        "filament-plugin",
        "filament plugin",
        "filament-theme",
        "filament theme",
        "theme",
        "dark-mode"
    ],
    "homepage": "https://github.com/rekuest/filament-rekuest-theme",
    "license": "MIT",
    "authors": [
        {
            "name": "Rekuest Srl",
            "homepage": "https://www.rekuest.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.28|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Rekuest\\FilamentRekuestTheme\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rekuest\\FilamentRekuestTheme\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rekuest\\FilamentRekuestTheme\\FilamentRekuestThemeServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
